{
  "name": "multistreamer",
  "version": "1.0.0",
  "description": "MultiStreamer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "app.multistreamer",
    "productName": "MultiStreamer",
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
